# ──────────────────────────────────────────────────────────────
# Homie — Apache config for Hostinger (shared hosting)
# ──────────────────────────────────────────────────────────────

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Force HTTPS (Hostinger terminates SSL at the load balancer)
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # Normalize www → apex (keep canonical URLs consistent with <link canonical>)
  RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [L,R=301]

  # SPA fallback — send all non-file, non-directory requests to index.html
  # so React Router handles /blog, /distritos/miraflores, /admin, etc.
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_URI} !^/api/
  RewriteRule ^ index.html [L]
</IfModule>

# ──────────────────────────────────────────────────────────────
# Cache headers — fingerprinted assets get long TTL, HTML gets none
# ──────────────────────────────────────────────────────────────

<IfModule mod_expires.c>
  ExpiresActive On

  # HTML — never cache (new deploys must be visible immediately)
  ExpiresByType text/html "access plus 0 seconds"

  # Vite outputs /assets/*.[hash].{js,css,woff2,...} — safe to cache forever
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType image/webp "access plus 1 month"
  ExpiresByType image/avif "access plus 1 month"
  ExpiresByType image/x-icon "access plus 1 month"

  # SEO files — weekly refresh
  ExpiresByType application/xml "access plus 1 week"
  ExpiresByType text/xml "access plus 1 week"
  ExpiresByType text/plain "access plus 1 week"
</IfModule>

<IfModule mod_headers.c>
  # Immutable for fingerprinted assets under /assets/
  <FilesMatch "\.(js|css|woff2|woff|ttf|eot|svg)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>

  # HTML never cached
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  # Security headers
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
  Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

# ──────────────────────────────────────────────────────────────
# Compression — serve gzipped assets when available
# ──────────────────────────────────────────────────────────────

<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# ──────────────────────────────────────────────────────────────
# Custom error page — SPA handles 404 via React Router / NotFound.tsx
# ──────────────────────────────────────────────────────────────

ErrorDocument 404 /index.html

# Pretty MIME types for modern assets
AddType application/manifest+json .webmanifest
AddType image/webp .webp
AddType image/avif .avif
AddType font/woff2 .woff2
